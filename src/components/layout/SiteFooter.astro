---
import navData from '@/data/navigation.json'
import site from '@/data/site.json'
import SocialIcon from '@/components/ui/SocialIcon.astro'

type Platform = 'Facebook' | 'Instagram' | 'LinkedIn'
---

<footer class="bg-ink" style="color: var(--paper);">
  <div
    class="mx-auto px-6 md:px-12 py-20 md:py-24 grid grid-cols-1 md:grid-cols-[2fr_1fr_1fr_1fr] gap-14 md:gap-10"
    style="max-width: 1280px;"
  >
    <!-- Brand -->
    <div>
      <a
        href="/"
        class="font-serif block mb-3"
        style="font-size: 2rem; font-weight: 400; color: var(--paper); letter-spacing: -0.01em; line-height: 1;"
      >
        After{' '}
        <em style="font-style: italic; color: var(--accent-soft);">the</em>{' '}
        Stork
      </a>
      <p
        class="font-mono uppercase tracking-[0.22em] mb-5"
        style="font-size: 0.75rem; color: var(--accent-soft);"
      >
        Est. {site.foundingYear} · Philadelphia
      </p>
      <p style="font-size: 0.875rem; color: rgba(244,239,230,.78); line-height: 1.7; max-width: 320px;">
        Expert overnight postpartum doula and newborn care for families across Philadelphia, the Main Line, Bucks County, and select communities in New Jersey.
      </p>
    </div>

    <!-- Services -->
    <div>
      <h4
        class="font-mono uppercase tracking-[0.22em] mb-6"
        style="font-size: 0.75rem; color: var(--accent-soft);"
      >
        Services
      </h4>
      <ul class="flex flex-col gap-3">
        {navData.footer[0].links.map((link) => (
          <li>
            <a href={link.href} class="footer-link" style="font-size: 0.875rem;">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Company -->
    <div>
      <h4
        class="font-mono uppercase tracking-[0.22em] mb-6"
        style="font-size: 0.75rem; color: var(--accent-soft);"
      >
        Company
      </h4>
      <ul class="flex flex-col gap-3">
        {navData.footer[1].links.map((link) => (
          <li>
            <a href={link.href} class="footer-link" style="font-size: 0.875rem;">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Contact -->
    <div>
      <h4
        class="font-mono uppercase tracking-[0.22em] mb-6"
        style="font-size: 0.75rem; color: var(--accent-soft);"
      >
        Contact
      </h4>
      <ul class="flex flex-col gap-3">
        <li>
          <a href={site.phone.href} class="footer-link" style="font-size: 0.875rem;">
            {site.phone.display}
          </a>
        </li>
        <li>
          <a href={site.email.href} class="footer-link" style="font-size: 0.875rem;">
            {site.email.display}
          </a>
        </li>
        {navData.footer[2].links.map((link) => (
          <li>
            <a href={link.href} class="footer-link" style="font-size: 0.875rem;">
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Social -->
      <ul class="flex flex-wrap gap-3 mt-6">
        {site.social.map((s) => (
          <li>
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.label}
              class="footer-link"
              style="display: inline-flex; align-items: center; justify-content: center; width: 2rem; height: 2rem; border-radius: 50%; border: 1px solid rgba(244,239,230,.2); transition: border-color 0.2s, color 0.2s;"
            >
              <SocialIcon platform={s.label as Platform} size={15} />
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Bottom bar -->
  <div
    class="mx-auto px-6 md:px-12 py-6 flex flex-col md:flex-row justify-between items-center gap-2 font-mono uppercase tracking-[0.14em]"
    style="max-width: 1280px; border-top: 1px solid rgba(255,255,255,.08); font-size: 0.75rem; color: rgba(244,239,230,.6);"
  >
    <span>© 2026 After the Stork — All rights reserved</span>
    <span>Legal</span>
  </div>
</footer>
