---
interface BreadcrumbItem {
  label: string
  href?: string
}

interface Props {
  items: BreadcrumbItem[]
}

const { items } = Astro.props
---

<nav
  class="flex items-center gap-2 font-mono text-muted"
  style="font-size: 0.75rem;"
  aria-label="Breadcrumb"
>
  <ol class="flex items-center gap-2 list-none">
    {items.map((item, i) => (
      <li class="flex items-center gap-2">
        {i > 0 && <span aria-hidden="true">·</span>}
        {item.href ? (
          <a href={item.href} class="hover:text-dim transition-colors">
            {item.label}
          </a>
        ) : (
          <span class="text-dim" aria-current="page">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
