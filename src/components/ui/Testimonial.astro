---
interface Props {
  quote: string
  attribution: string
  class?: string
}

const { quote, attribution, class: className = '' } = Astro.props
---

<div
  class={`border bg-paper p-10 transition-colors duration-300 hover:border-accent ${className}`}
  style="border-color: var(--stroke);"
>
  <span
    class="font-serif italic select-none block text-accent-soft text-[5rem] leading-[0.7] mb-3.5"
    aria-hidden="true"
  >
    &ldquo;
  </span>
  <p class="font-serif italic text-ink-soft text-[1.375rem] leading-[1.45]">
    {quote}
  </p>
  <div
    class="flex items-center gap-3 mt-6 font-mono uppercase tracking-[0.18em]"
    style="font-size: 0.75rem; color: var(--mid);"
  >
    <span
      aria-hidden="true"
      style="display: inline-block; width: 20px; height: 1px; background: var(--stroke); flex-shrink: 0;"
    />
    {attribution}
  </div>
</div>
