---
interface Props {
  class?: string
  center?: boolean
  dark?: boolean
}
const { class: className = '', center = false, dark = false } = Astro.props
const color = dark ? 'var(--accent-soft)' : 'var(--accent)'
---
<div class={`flex items-center gap-3 ${center ? 'justify-center' : ''} ${className}`} style="margin-bottom: 1.375rem;">
  <span aria-hidden="true" style={`display: inline-block; width: 28px; height: 1px; background: ${color}; flex-shrink: 0;`}></span>
  <span class="font-mono uppercase tracking-[0.22em]" style={`font-size: 0.75rem; color: ${color};`}>
    <slot />
  </span>
</div>
