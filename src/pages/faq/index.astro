---
import Layout from '@/layouts/Layout.astro'
import Button from '@/components/ui/Button.astro'
import FAQItem from '@/components/ui/FAQItem'
import type { FAQCategory } from '@/types'
import faqsData from '@/data/faqs.json'

const faqs = faqsData as FAQCategory[]
---

<Layout
  title="Postpartum Doula FAQs | After the Stork Philadelphia"
  description="Have questions about postpartum doula and overnight newborn care? Find answers from the After the Stork team — Philadelphia and the Main Line's premier and longest-running postpartum doula agency since 2006."
>

  <section class="py-20 bg-paper">
    <div class="mx-auto px-6 md:px-12" style="max-width: 1280px;">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="pill">FAQ</div>
          <h1 class="font-serif font-light text-ink text-display">
            Your Questions,<br /><em>Answered.</em>
          </h1>
        </div>
        <div>
          <p class="text-dim" style="font-size: 0.9375rem; max-width: 440px; line-height: 1.75;">
            We know choosing postpartum support is a big decision. Below are the questions we hear most often from families in Philadelphia and the Main Line.
          </p>
        </div>
      </div>
    </div>
  </section>

  <div style="border-bottom: var(--rule);">
    <div class="mx-auto px-6 md:px-12 flex flex-wrap gap-8 items-center" style="max-width: 1280px; padding: 32px 3.5rem;">
      <span class="font-mono uppercase tracking-[0.18em] text-mid" style="font-size: 0.75rem;">Jump to:</span>
      {faqs.map((cat, i) => (
        <a
          href={`#faq-${i}`}
          class="font-mono uppercase tracking-[0.18em] text-dim hover:text-ink transition-colors"
          style="font-size: 0.75rem; border-bottom: 1px solid var(--accent); padding-bottom: 2px;"
        >
          {cat.category}
        </a>
      ))}
    </div>
  </div>

  {faqs.map((category, catIndex) => (
    <section
      id={`faq-${catIndex}`}
      class={`py-20 ${catIndex % 2 === 0 ? 'bg-canvas' : 'bg-paper'}`}
    >
      <div class="mx-auto px-6 md:px-12" style="max-width: 900px;">
        <div class="flex items-end justify-between mb-8">
          <p class="font-mono text-dim uppercase tracking-[0.22em]" style="font-size: 0.75rem;">{category.category}</p>
          <div class="font-serif font-light italic hidden md:block select-none text-accent-tint text-numeral" aria-hidden="true">
            {String(catIndex + 1).padStart(2, '0')}
          </div>
        </div>
        {category.items.map((item, itemIndex) => (
          <FAQItem
            question={item.question}
            answer={item.answer}
            isLast={itemIndex === category.items.length - 1}
            client:load
          />
        ))}
      </div>
    </section>
  ))}

  <section class="py-20 bg-ink">
    <div class="mx-auto px-6 md:px-12" style="max-width: 1280px;">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-12 items-center">
        <div>
          <h2 class="font-serif font-light text-paper text-h1">Still Have Questions?</h2>
          <p class="mt-3" style="font-size: 0.9375rem; max-width: 480px; color: rgba(244,239,230,.75); line-height: 1.75;">
            We're happy to answer anything not covered above. Reach out directly — or book a free consultation and we'll walk you through everything.
          </p>
        </div>
        <div>
          <Button variant="inverse" href="/contact">Contact Us</Button>
        </div>
      </div>
    </div>
  </section>

</Layout>
