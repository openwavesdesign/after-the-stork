---
import { getCollection } from 'astro:content'
import Layout from '@/layouts/Layout.astro'
import Button from '@/components/ui/Button.astro'
import Eyebrow from '@/components/ui/Eyebrow.astro'
import Media from '@/components/ui/Media.astro'
import Reveal from '@/components/ui/Reveal'
import { formatDate, getCategories } from '@/lib/posts'

const allPosts = await getCollection('blog', ({ data }) => data.active !== false)
const posts = allPosts.sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date))
const featured = posts[0]
const rest = posts.slice(1)
const categories = getCategories(posts)
---

<Layout
  title="Postpartum Doula Blog | After the Stork Philadelphia"
  description="Expert insights on postpartum recovery, newborn care, breastfeeding, and infant sleep from the After the Stork team — Philadelphia's premier postpartum doula agency since 2006."
>

  <section class="py-20 bg-paper">
    <div class="mx-auto px-6 md:px-12" style="max-width: 1280px;">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="pill">Blog</div>
          <h1 class="font-serif font-light text-ink text-display">
            The After<br /><em>the Stork Blog.</em>
          </h1>
        </div>
        <div>
          <p class="text-dim" style="font-size: 0.9375rem; max-width: 440px; line-height: 1.75;">
            Postpartum recovery, newborn care, breastfeeding, and infant sleep — written by the team behind Philadelphia's premier postpartum doula agency, with an IBCLC on staff and a Certified Gentle Sleep Coach.
          </p>
        </div>
      </div>
    </div>
  </section>

  {featured && (
    <section class="py-20 bg-canvas">
      <div class="mx-auto px-6 md:px-12" style="max-width: 1280px;">
        <div class="grid grid-cols-1 lg:grid-cols-[5fr_7fr] gap-16 items-center">
          <Media
            src={featured.data.featuredImage}
            alt={featured.data.title}
            label={`${featured.data.category} · Featured`}
            ratio="3/2"
          />
          <div>
            <Eyebrow>Featured</Eyebrow>
            <span class="area-tag mb-4 inline-block">{featured.data.category}</span>
            <h2 class="font-serif font-light text-ink text-h3 mb-3">{featured.data.title}</h2>
            <div class="font-mono uppercase tracking-[0.16em] flex flex-wrap gap-4 mb-5" style="font-size: 0.75rem; color: var(--mid);">
              <span>{formatDate(featured.data.date)}</span>
              <span aria-hidden="true">·</span>
              <span>{featured.data.readingTime}</span>
              <span aria-hidden="true">·</span>
              <span>{featured.data.author}</span>
            </div>
            <p class="text-dim mb-6" style="font-size: 0.9375rem; line-height: 1.75;">{featured.data.metaDescription}</p>
            <Button variant="ghost" href={`/blog/${featured.slug}`}>Read the Post</Button>
          </div>
        </div>
      </div>
    </section>
  )}

  <section style="border-bottom: var(--rule);">
    <div class="mx-auto px-6 md:px-12 py-6 flex justify-between items-center flex-wrap gap-6" style="max-width: 1280px;">
      <div class="flex gap-2 flex-wrap">
        <span class="area-tag" style="border-color: var(--ink); color: var(--ink); font-weight: 500;">All Posts</span>
        {categories.map((c) => (
          <span class="area-tag">{c}</span>
        ))}
      </div>
      <span class="font-mono uppercase tracking-[0.18em] text-mid" style="font-size: 0.75rem;">
        {posts.length} {posts.length === 1 ? 'post' : 'posts'}
      </span>
    </div>
  </section>

  <section class="py-20 bg-paper">
    <div class="mx-auto px-6 md:px-12" style="max-width: 1280px;">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {rest.map((post, i) => (
          <Reveal delay={(i % 3) * 80} client:visible>
            <a
              href={`/blog/${post.slug}`}
              class="group block border bg-paper overflow-hidden transition-all duration-300 hover:border-accent hover:-translate-y-1 h-full"
              style="border-color: var(--stroke);"
            >
              <Media
                src={post.data.featuredImage}
                alt={post.data.title}
                label={post.data.category}
                ratio="16/10"
              />
              <div class="px-6 py-7" style="border-top: var(--rule-soft);">
                <span class="area-tag mb-3 inline-block">{post.data.category}</span>
                <p class="font-serif text-ink font-light leading-tight mb-3" style="font-size: 1.25rem;">{post.data.title}</p>
                <p class="font-mono uppercase tracking-[0.18em]" style="font-size: 0.75rem; color: var(--mid);">
                  {formatDate(post.data.date)} · {post.data.readingTime}
                </p>
              </div>
            </a>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-ink">
    <div class="mx-auto px-6 md:px-12" style="max-width: 1280px;">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <Eyebrow dark>Stay in the Loop</Eyebrow>
          <h2 class="font-serif font-light text-paper text-h2">
            Get Postpartum Insights<br /><em style="color: var(--accent-soft);">Delivered to Your Inbox.</em>
          </h2>
          <p class="mt-4" style="font-size: 0.9375rem; color: rgba(244,239,230,.75); line-height: 1.75;">
            Practical tips, honest advice, and resources for new and expecting families. No noise, just good stuff.
          </p>
        </div>
        <div>
          <label for="newsletter-email" class="sr-only">Email address</label>
          <div style="display: flex; border: 1px solid rgba(255,255,255,.2);">
            <input
              id="newsletter-email"
              type="email"
              placeholder="Email address"
              class="flex-1 outline-none"
              style="background: rgba(255,255,255,.05); color: var(--paper); font-family: var(--font-serif); font-size: 1rem; padding: 16px 18px; border: none;"
            />
            <button
              class="font-mono uppercase tracking-[0.16em] hover:bg-ghost transition-colors whitespace-nowrap"
              style="background: var(--paper); color: var(--ink); font-size: 0.75rem; padding: 0 24px;"
            >
              Subscribe &rarr;
            </button>
          </div>
          <p class="font-mono mt-2" style="font-size: 0.75rem; color: rgba(244,239,230,.35); letter-spacing: .1em;">
            We'll only send things worth reading. Unsubscribe anytime.
          </p>
        </div>
      </div>
    </div>
  </section>

</Layout>
