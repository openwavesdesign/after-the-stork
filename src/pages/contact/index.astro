---
import Layout from '@/layouts/Layout.astro'
import Eyebrow from '@/components/ui/Eyebrow.astro'
import SocialIcon from '@/components/ui/SocialIcon.astro'
import ContactFormEmbed from '@/components/contact/ContactFormEmbed'
import site from '@/data/site.json'
---

<Layout
  title="Contact After the Stork | Philadelphia Postpartum Doula Team"
  description="Ready to get started? Contact After the Stork to book a free consultation or ask questions about postpartum doula services in Philadelphia and the Main Line."
>

  <section class="py-20 bg-paper">
    <div class="mx-auto px-6 md:px-12" style="max-width: 1280px;">
      <div class="pill">Contact Us</div>
      <h1 class="font-serif font-light text-ink text-display max-w-[900px]">
        Contact Our Philadelphia <em>Postpartum Doula</em> Team
      </h1>
      <p class="mt-6" style="font-size: 1.125rem; color: var(--dim); line-height: 1.7; max-width: 560px;">
        Whether you're planning ahead during pregnancy, newly home from the hospital, or still figuring out what kind of support you need — reach out. There are no silly questions here. We typically respond within one business day.
      </p>
    </div>
  </section>

  <section class="py-20 bg-canvas">
    <div class="mx-auto px-6 md:px-12" style="max-width: 1280px;">
      <div class="grid grid-cols-1 lg:grid-cols-[7fr_5fr] gap-20 items-start">
        <div>
          <Eyebrow>Send a Message</Eyebrow>
          <div style="background: var(--paper); border: var(--rule); padding: 12px;">
            <ContactFormEmbed client:load />
          </div>
        </div>

        <div>
          <Eyebrow>Get in Touch</Eyebrow>
          <h2 class="font-serif font-light text-ink text-h3 mb-8">Direct Contact</h2>

          <div style="border-top: var(--rule-soft); padding: 1.5rem 0; display: flex; align-items: flex-start; gap: 1.25rem;">
            <span class="font-serif" style="font-size: 1.75rem; color: var(--accent); line-height: 1;" aria-hidden="true">☏</span>
            <div>
              <p class="font-mono uppercase tracking-[0.2em]" style="font-size: 0.75rem; color: var(--mid); margin-bottom: 6px;">Phone</p>
              <a href={site.phone.href} class="font-serif hover:text-accent transition-colors" style="font-size: 1.375rem; color: var(--ink); line-height: 1;">{site.phone.display}</a>
            </div>
          </div>

          <div style="border-top: var(--rule-soft); padding: 1.5rem 0; display: flex; align-items: flex-start; gap: 1.25rem;">
            <span class="font-serif" style="font-size: 1.75rem; color: var(--accent); line-height: 1;" aria-hidden="true">✉</span>
            <div>
              <p class="font-mono uppercase tracking-[0.2em]" style="font-size: 0.75rem; color: var(--mid); margin-bottom: 6px;">Email</p>
              <a href={site.email.href} class="font-serif hover:text-accent transition-colors" style="font-size: 1.375rem; color: var(--ink); line-height: 1;">{site.email.display}</a>
            </div>
          </div>

          <div style="border-top: var(--rule-soft); padding: 1.5rem 0; display: flex; align-items: flex-start; gap: 1.25rem;">
            <span class="font-serif" style="font-size: 1.75rem; color: var(--accent); line-height: 1;" aria-hidden="true">◎</span>
            <div>
              <p class="font-mono uppercase tracking-[0.2em]" style="font-size: 0.75rem; color: var(--mid); margin-bottom: 6px;">Service Area</p>
              <span class="font-serif" style="font-size: 1.375rem; color: var(--ink); line-height: 1.35;">{site.serviceArea}</span>
            </div>
          </div>

          <div class="flex flex-wrap gap-2 mt-2 mb-8">
            {['Philadelphia', 'Bryn Mawr', 'Wayne', 'Villanova', 'Dresher', 'Moorestown NJ', 'Haddonfield NJ'].map((area) => (
              <span class="area-tag">{area}</span>
            ))}
          </div>

          <div style="border-top: var(--rule-soft); padding-top: 1.5rem;">
            <p class="font-mono uppercase tracking-[0.2em] mb-3" style="font-size: 0.75rem; color: var(--mid);">Follow Along</p>
            <div class="flex flex-wrap gap-3">
              {site.social.map((s) => (
                <a
                  href={s.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={s.label}
                  class="hover:text-accent transition-colors"
                  style="display: inline-flex; align-items: center; justify-content: center; width: 2.25rem; height: 2.25rem; border-radius: 50%; border: 1px solid var(--rule); color: var(--dim);"
                >
                  <SocialIcon platform={s.label as 'Facebook' | 'Instagram' | 'LinkedIn'} size={16} />
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-ink">
    <div class="mx-auto px-6 md:px-12" style="max-width: 1280px;">
      <p class="font-serif font-light italic text-center text-paper text-h2">
        We look forward to supporting your family.
      </p>
    </div>
  </section>

</Layout>
